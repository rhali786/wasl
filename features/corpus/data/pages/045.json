ِ","en":"all (kinds)","type":"word","ayah":266,"key":"2:266","id":"كل"},{"t":"ٱلثَّمَرَٰتِ","en":"(of) [the] fruits","type":"word","ayah":266,"key":"2:266","id":"الثمرت"},{"t":"وَأَصَابَهُ","en":"and strikes him","type":"word","ayah":266,"key":"2:266","id":"واصابه"},{"t":"ٱلْكِبَرُ","en":"[the] old age","type":"word","ayah":266,"key":"2:266","id":"الكبر"},{"t":"وَلَهُۥ","en":"and [for] his","type":"word","ayah":266,"key":"2:266","id":"وله"},{"t":"ذُرِّيَّةٌۭ","en":"children","type":"word","ayah":266,"key":"2:266","id":"ذرية"},{"t":"ضُعَفَآءُ","en":"(are) weak","type":"word","ayah":266,"key":"2:266","id":"ضعفاء"}]},{"line":7,"words":[{"t":"فَأَصَابَهَآ","en":"then falls on it","type":"word","ayah":266,"key":"2:266","id":"فاصابها"},{"t":"إِعْصَارٌۭ","en":"whirlwind","type":"word","ayah":266,"key":"2:266","id":"اعصار"},{"t":"فِيهِ","en":"in it","type":"word","ayah":266,"key":"2:266","id":"فيه"},{"t":"نَارٌۭ","en":"(is) fire","type":"word","ayah":266,"key":"2:266","id":"نار"},{"t":"فَٱحْتَرَقَتْ ۗ","en":"then it is burnt","type":"word","ayah":266,"key":"2:266","id":"فاحترقت"},{"t":"كَذَٰلِكَ","en":"Thus","type":"word","ayah":266,"key":"2:266","id":"كذلك"},{"t":"يُبَيِّنُ","en":"makes clear","type":"word","ayah":266,"key":"2:266","id":"يبين"},{"t":"ٱللَّهُ","en":"Allah","type":"word","ayah":266,"key":"2:266","id":"الله"}]},{"line":8,"words":[{"t":"لَكُمُ","en":"for you","type":"word","ayah":266,"key":"2:266","id":"لكم"},{"t":"ٱلْـَٔايَـٰتِ","en":"(His) Signs","type":"word","ayah":266,"key":"2:266","id":"الايت"},{"t":"لَعَلَّكُمْ","en":"so that you may","type":"word","ayah":266,"key":"2:266","id":"لعلكم"},{"t":"تَتَفَكَّرُونَ","en":"ponder","type":"word","ayah":266,"key":"2:266","id":"تتفكرون"},{"t":"٢٦٦","en":"(266)","type":"end","ayah":266,"key":"2:266","id":"٢٦٦"},{"t":"يَـٰٓأَيُّهَا","en":"O you","type":"word","ayah":267,"key":"2:267","id":"يايها"},{"t":"ٱلَّذِينَ","en":"who","type":"word","ayah":267,"key":"2:267","id":"الذين"}]},{"line":9,"words":[{"t":"ءَامَنُوٓا۟