# ─────────────────────────────────────────────────────────────────
# Wird — environment variables
#
# Next.js loads (project root): `.env`, then `.env.local` (overrides).
# For local dev: copy this file to `.env.local` and fill in the values below.
# Never commit `.env` or `.env.local` — both are gitignored.
#
# Set the same vars in your hosting provider's Environment settings for production.
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────

# Auth.js v5 secret — signs JWTs and cookies (middleware will error without it).
# Generate: openssl rand -base64 32
DATABASE_URL=postgresql://wird_user:REPLACE_WITH_PASSWORD@REPLACE_WITH_HOST:5432/wird

AUTH_SECRET=

# Canonical app URL for OAuth redirects — required for local Google sign-in.
# Without this, Auth.js uses the browser Host header and OAuth providers return redirect_uri_mismatch.
AUTH_URL=http://localhost:3000

# PostgreSQL database connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Optional ──────────────────────────────────────────────────────

# Optional individual PostgreSQL fields, if a script/tool expects split values instead of DATABASE_URL.
# POSTGRES_HOST=REPLACE_WITH_HOST
# POSTGRES_PORT=5432
# POSTGRES_DB=wird
# POSTGRES_USER=wird_user
# POSTGRES_PASSWORD=REPLACE_WITH_PASSWORD

# ── Dev / preview bypass ──────────────────────────────────────────
# Set BOTH vars to enable a password-protected dev login on the sign-in page.
# Leave unset (or remove) in production to disable completely.
#
# DEV_BYPASS_SECRET=your-secret-here
# NEXT_PUBLIC_DEV_MODE=true

# ── OAuth ───────────────────────────────────────────────────────────
# When AUTH_GOOGLE_ID + AUTH_GOOGLE_SECRET are set, login shows the Google button.
# Local redirect URIs must be allowlisted, e.g. http://localhost:3000/api/auth/callback/google
#
# Google: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
